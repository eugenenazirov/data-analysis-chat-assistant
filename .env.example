# Optional Gemini API key from Google AI Studio. If left empty, Gemini chat and
# embeddings can use Vertex AI through Application Default Credentials when
# GOOGLE_CLOUD_PROJECT and GOOGLE_CLOUD_LOCATION are set.
GOOGLE_API_KEY=

# Google Cloud project used by BigQuery client authentication.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_QUOTA_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
BIGQUERY_LOCATION=US
BQ_MAX_BYTES_BILLED=200000000

# Compose default. For local Python runs, use http://localhost:6333.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=golden_trios
GOLDEN_TOP_K=3

LLM_MODEL=google-cloud:gemini-2.5-flash
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
MAX_SQL_RETRIES=2
MAX_AGENT_REQUESTS=8
MAX_TOOL_CALLS=6
MAX_AGENT_TOKENS=32000
MAX_OUTPUT_RETRIES=2
MAX_CHAT_HISTORY_TURNS=6
MAX_CHAT_HISTORY_BYTES=65536
CHART_TIMEOUT_SECONDS=10

# Optional observability integrations.
AGENT_LOG_PATH=logs/agent-runs.jsonl
OTEL_EXPORTER_OTLP_ENDPOINT=
LOGFIRE_TOKEN=
