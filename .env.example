# Optional Gemini Developer API key from Google AI Studio. `google:` chat models
# and their Gemini embeddings can use this key. The default `google-cloud:` route
# uses Vertex AI for both chat and embeddings through Application Default
# Credentials and does not consume the key.
GOOGLE_API_KEY=

# Google Cloud project used by BigQuery client authentication.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_QUOTA_PROJECT=
# Chat uses Google's global Vertex endpoint by default. Embeddings stay regional
# when configured to use Vertex AI rather than the Developer API.
GOOGLE_CLOUD_LLM_LOCATION=global
# A terminal retryable error fails over within the same model request, so
# completed BigQuery work is never repeated.
GOOGLE_CLOUD_LLM_FALLBACK_LOCATION=us-central1
GOOGLE_CLOUD_EMBEDDING_LOCATION=us-central1
# Legacy compatibility fallback for deployments that still set one location.
GOOGLE_CLOUD_LOCATION=
BIGQUERY_LOCATION=US
BQ_MAX_BYTES_BILLED=200000000

# Compose default. For local Python runs, use http://localhost:6333.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=golden_trios
GOLDEN_TOP_K=3

LLM_MODEL=google-cloud:gemini-3.5-flash
# Per transport attempt. Three attempts keep transient failures recoverable while
# preventing a dead provider request from stalling reviewer flows indefinitely.
LLM_REQUEST_TIMEOUT_SECONDS=120
# Keep thinking disabled for lower-latency, deterministic tool orchestration.
# Increase only after a measured bakeoff.
LLM_THINKING_BUDGET=0
LLM_MAX_OUTPUT_TOKENS=2048
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
MAX_SQL_RETRIES=2
MAX_CHART_RETRIES=2
MAX_AGENT_REQUESTS=8
MAX_TOOL_CALLS=6
MAX_AGENT_TOKENS=32000
MAX_OUTPUT_RETRIES=1
MAX_CHAT_HISTORY_TURNS=6
MAX_CHAT_HISTORY_BYTES=65536
CHART_TIMEOUT_SECONDS=10

# Optional observability integrations.
AGENT_LOG_PATH=logs/agent-runs.jsonl
OTEL_EXPORTER_OTLP_ENDPOINT=
LOGFIRE_TOKEN=
