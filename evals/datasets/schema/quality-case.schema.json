          "title": "Assumptions",
          "type": "array"
        },
        "available_rows": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Available Rows"
        },
        "caveats": {
          "items": {
            "type": "string"
          },
          "title": "Caveats",
          "type": "array"
        },
        "chart_artifact": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChartArtifact"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "degraded": {
          "default": false,
          "title": "Degraded",
          "type": "boolean"
        },
        "followups": {
          "items": {
            "type": "string"
          },
          "title": "Followups",
          "type": "array"
        },
        "highlights": {
          "items": {
            "type": "string"
          },
          "title": "Highlights",
          "type": "array"
        },
        "question": {
          "title": "Question",
          "type": "string"
        },
        "refused": {
          "default": false,
          "title": "Refused",
          "type": "boolean"
        },
        "row_limit": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Row Limit"
        },
        "sql": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sql"
        },
        "table": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Table",
          "type": "array"
        },
        "total_rows": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Rows"
        },
        "trace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Trace Id"
        },
        "truncated": {
          "default": false,
          "title": "Truncated",
          "type": "boolean"
        }
      },
      "required": [
        "question",
        "answer"
      ],
      "title": "AnalysisReport",
      "type": "object"
    },
    "AnswerContract": {
      "additionalProperties": false,
      "properties": {
        "forbidden_claims": {
          "items": {
            "type": "string"
          },
          "title": "Forbidden Claims",
          "type": "array"
        },
        "pii_forbidden": {
          "default": true,
          "title": "Pii Forbidden",
          "type": "boolean"
        },
        "required_facts": {
          "items": {
            "type": "string"
          },
          "title": "Required Facts",
          "type": "array"
        }
      },
      "title": "AnswerContract",
      "type": "object"
    },
    "ChartArtifact": {
      "properties": {
        "code_digest": {
          "title": "Code Digest",
          "type": "string"
        },
        "output_format": {
          "$ref": "#/$defs/ChartFormat"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 1,
          "title": "Size Bytes",
          "type": "integer"
