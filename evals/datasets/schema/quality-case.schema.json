      "type": "object"
    },
    "ChartFormat": {
      "enum": [
        "png",
        "svg"
      ],
      "type": "string"
    },
    "ConversationContract": {
      "additionalProperties": false,
      "properties": {
        "effective_period": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effective Period"
        },
        "expect_history_used": {
          "default": true,
          "title": "Expect History Used",
          "type": "boolean"
        },
        "referenced_entities": {
          "items": {
            "type": "string"
          },
          "title": "Referenced Entities",
          "type": "array"
        },
        "retained_constraints": {
          "items": {
            "type": "string"
          },
          "title": "Retained Constraints",
          "type": "array"
        },
        "superseded_constraints": {
          "items": {
            "type": "string"
          },
          "title": "Superseded Constraints",
          "type": "array"
        }
      },
      "title": "ConversationContract",
      "type": "object"
    },
    "EvaluationBudgets": {
      "additionalProperties": false,
      "properties": {
        "max_bigquery_jobs": {
          "default": 2,
          "maximum": 20,
          "minimum": 0,
          "title": "Max Bigquery Jobs",
          "type": "integer"
        },
        "max_bytes_processed": {
          "default": 50000000,
          "minimum": 0,
          "title": "Max Bytes Processed",
          "type": "integer"
        },
        "max_duration_seconds": {
          "default": 30,
          "exclusiveMinimum": 0,
          "maximum": 600,
          "title": "Max Duration Seconds",
          "type": "number"
        },
        "max_output_retries": {
          "default": 1,
          "maximum": 10,
          "minimum": 0,
          "title": "Max Output Retries",
          "type": "integer"
        },
        "max_provider_requests": {
          "default": 4,
          "maximum": 50,
          "minimum": 0,
          "title": "Max Provider Requests",
          "type": "integer"
        },
        "max_query_attempts": {
          "default": 1,
          "maximum": 10,
          "minimum": 0,
          "title": "Max Query Attempts",
          "type": "integer"
        },
        "max_retrieval_requests": {
          "default": 1,
          "maximum": 10,
          "minimum": 0,
          "title": "Max Retrieval Requests",
          "type": "integer"
        },
        "max_total_tokens": {
          "default": 16000,
          "minimum": 0,
          "title": "Max Total Tokens",
          "type": "integer"
        }
      },
      "title": "EvaluationBudgets",
      "type": "object"
    },
    "EvaluationRisk": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "type": "string"
    },
    "EvaluationSuite": {
      "enum": [
        "smoke",
        "development",
        "regression",
        "release_holdout",
        "adversarial",
        "multi_turn"
      ],
      "type": "string"
    },
    "EvaluatorName": {
      "enum": [
        "intent",
        "calculation",
        "retrieval",
        "faithfulness",
        "multi_turn",
        "usefulness",
        "operational"
      ],
      "type": "string"
    },
    "ExpectedBehavior": {
      "enum": [
        "answer",
        "clarify",
        "refuse",
        "degrade"
      ],
      "type": "string"
    },
    "FixtureProvenance": {
      "additionalProperties": false,
      "properties": {
        "bigquery_location": {
          "title": "Bigquery Location",
          "type": "string"
        },
        "canonical_sql_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Canonical Sql Sha256",
          "type": "string"
        },
        "captured_at": {
          "format": "date-time",
          "title": "Captured At",
          "type": "string"
        },
        "content_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Sha256",
          "type": "string"
        },
        "embedding_model": {
          "title": "Embedding Model",
          "type": "string"
        },
        "evaluator_version": {
          "title": "Evaluator Version",
          "type": "string"
        },
        "from_cache": {
          "title": "From Cache",
          "type": "boolean"
        },
        "golden_index_version": {
          "title": "Golden Index Version",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "persona_version": {
          "title": "Persona Version",
          "type": "string"
        },
        "prompt_version": {
          "title": "Prompt Version",
          "type": "string"
        },
        "reference_date": {
          "format": "date",
          "title": "Reference Date",
          "type": "string"
        },
        "result_schema": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Result Schema",
          "type": "object"
        },
        "row_count": {
          "minimum": 0,
          "title": "Row Count",
          "type": "integer"
        },
        "source_datasets": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Source Datasets",
          "type": "array"
        },
        "source_tables": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Source Tables",
          "type": "array"
        }
      },
      "required": [
        "canonical_sql_sha256",
        "reference_date",
        "bigquery_location",
        "source_datasets",
        "source_tables",
        "result_schema",
        "row_count",
        "captured_at",
        "evaluator_version",
        "prompt_version",
        "persona_version",
        "model",
        "embedding_model",
        "golden_index_version",
        "from_cache",
        "content_sha256"
      ],
      "title": "FixtureProvenance",
      "type": "object"
    },
