        },
        "succeeded": {
          "title": "Succeeded",
          "type": "boolean"
        },
        "trusted": {
          "title": "Trusted",
          "type": "boolean"
        }
      },
      "required": [
        "question",
        "succeeded",
        "trusted"
      ],
      "title": "HistoryTurnReplay",
      "type": "object"
    },
    "JoinKey": {
      "additionalProperties": false,
